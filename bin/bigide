#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export BIGIDE_REPO_ROOT="$REPO_ROOT"

source "$REPO_ROOT/src/shell/lib/common.sh"
source "$REPO_ROOT/src/shell/lib/setup-runtime.sh"
source "$REPO_ROOT/src/shell/lib/splash.sh"
source "$REPO_ROOT/src/shell/lib/session.sh"
source "$REPO_ROOT/src/shell/lib/layout.sh"
source "$REPO_ROOT/src/shell/lib/deps.sh"
source "$REPO_ROOT/src/shell/lib/repair.sh"
source "$REPO_ROOT/src/shell/lib/update.sh"
source "$REPO_ROOT/src/shell/lib/ccproxy.sh"
source "$REPO_ROOT/src/shell/lib/provision.sh"

# Colori per output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

usage() {
  cat <<'TXT'
Usage:
  bigide [project_path] [--layout name]
  bigide --repair
  bigide --update
  bigide --install-ccproxy
TXT
}

LAYOUT_NAME="default"

case "${1:-}" in
  --repair)
    init_runtime
    repair_runtime
    exit 0
    ;;
  --update)
    init_runtime
    update_bigide
    exit 0
    ;;
  --layout)
    LAYOUT_NAME="${2:-default}"
    shift 2
    ;;
esac

PROJECT_PATH="${1:-$PWD}"
# Se dopo shift 2 il path non c'è, usa PWD.
# Se PROJECT_PATH era --layout, lo shift lo ha tolto.
# Ma se l'utente fa `bigide . --layout web`, dobbiamo gestire entrambi.

# Fix per argomenti misti
for arg in "$@"; do
  if [[ "$arg" == "--layout" ]]; then
     # Già gestito o da gestire nel loop
     :
  fi
done

SESSION_NAME="$(session_name_for_path "$PROJECT_PATH")"

show_splash "Verifica dipendenze" 10
ensure_dependencies
show_splash "Inizializzazione runtime" 35
init_runtime

# 1.5 Auto-provisioning
check_auto_provision "$PROJECT_PATH"

if session_exists "$SESSION_NAME"; then
  end_splash
  echo -e "\n${YELLOW}La sessione '$SESSION_NAME' esiste già.${NC}"
  echo -e "Cosa vuoi fare?"
  echo -e "  ${GREEN}[r] Riprendi${NC} (attach)"
  echo -e "  ${RED}[k] Riavvia${NC} (kill & restart)"
  echo -e "  [c] Annulla"
  read -p "> " choice
  
  case "$choice" in
    k|K)
      show_splash "Chiusura sessione esistente" 70
      tmux kill-session -t "$SESSION_NAME"
      ;;
    c|C)
      exit 0
      ;;
    *)
      show_splash "Aggancio sessione" 80
      end_splash
      if [ -n "${TMUX:-}" ]; then
        exec tmux switch-client -t "$SESSION_NAME"
      else
        exec tmux attach -t "$SESSION_NAME"
      fi
      ;;
  esac
fi

show_splash "Creazione nuova sessione" 60
tmux new-session -d -s "$SESSION_NAME" -c "$PROJECT_PATH"
tmux source-file "$HOME/.bigide/tmux/tmux.conf" 2>/dev/null || true
show_splash "Creazione layout: $LAYOUT_NAME" 85
create_layout "$SESSION_NAME" "$LAYOUT_NAME"
show_splash "Pronto" 100
end_splash

if [ -n "${TMUX:-}" ]; then
  exec tmux switch-client -t "$SESSION_NAME"
else
  exec tmux attach -t "$SESSION_NAME"
fi
